    "id": 1,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "title": "Shopify Sync Operations (Success vs Failure)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(rate(shopify_sync_total{status='success'}[5m]))",
                    "legendFormat": "Successful Sync"
                },
                {
                    "expr": "sum(rate(shopify_sync_total{status='failed'}[5m]))",
                    "legendFormat": "Failed Sync"
                }
            ]
        },
        {
            "title": "AI Token Consumption (Input vs Output)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "sum(rate(ai_usage_tokens_total{type='input'}[5m]))",
                    "legendFormat": "Input Tokens"
                },
                {
                    "expr": "sum(rate(ai_usage_tokens_total{type='output'}[5m]))",
                    "legendFormat": "Output Tokens"
                }
            ]
        },
        {
            "title": "Orders Processed Over Time",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "sum(rate(orders_processed_total[5m]))",
                    "legendFormat": "Processed Orders"
                }
            ]
        },
        {
            "title": "Reports Generated by Type",
            "type": "barchart",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "targets": [
                {
                    "expr": "sum(reports_generated_total) by (type)",
                    "legendFormat": "{{type}}"
                }
            ]
        },
        {
            "title": "System Memory Usage",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes / 1024 / 1024",
                    "legendFormat": "Residuary Memory (MB)"
                }
            ]
        },
        {
            "title": "HTTP Request Latency (P99)",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P99 Latency (s)"
                }
            ]
        },
        {
            "title": "Image Upload Success Rate",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 24
            },
            "targets": [
                {
                    "expr": "sum(rate(image_uploads_total{status='success'}[5m]))",
                    "legendFormat": "Successful Uploads"
                },
                {
                    "expr": "sum(rate(image_uploads_total{status='error'}[5m]))",
                    "legendFormat": "Failed Uploads"
                }
            ]
        },
        {
            "title": "Cloudinary Upload Latency",
            "type": "timeseries",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 24
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(image_upload_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P95 Latency (s)"
                }
            ]
        }
    ],
