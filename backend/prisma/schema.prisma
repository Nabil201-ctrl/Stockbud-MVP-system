datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  name                  String
  password              String?
  picture               String?
  shopifyShop           String?
  shopifyToken          String?
  activeShopId          String?
  storeLimit            Int            @default(1)
  retentionMonths       Int            @default(3)
  createdAt             DateTime       @default(now())
  isOnboardingComplete  Boolean        @default(false)
  refreshToken          String?
  aiTokens              Int            @default(500)
  reportTokens          Int            @default(250)
  botSettings           Json?
  lastTokenReset        String?
  requiresPasswordChange Boolean        @default(false)
  isVerified            Boolean        @default(false)
  verificationToken     String?


  hasFreeReports        Boolean        @default(false)
  language              String         @default("en")
  pushSubscription      Json?
  ipAddress             String?
  location              String?
  currency              String?
  signInCount           Int            @default(0)
  lastLoginDate         DateTime?
  loginDates            String[]       @default([])
  telegramChatId        String?
  // Plan system
  plan                  String         @default("free")
  aiActionsUsed         Int            @default(0)
  aiActionsResetDate    DateTime?

  shopifyStores         ShopifyStore[]
  socialStores          SocialStore[]
  orders                Order[]
  notifications         Notification[]
  chats                 Chat[]
  products              Product[]      // New Relation
  syncHistory           SyncHistory[]  // New Relation
  traceRecords          TraceRecord[]  // New Relation (Auditing)
}

model ShopifyStore {
  id           String      @id @default(uuid())
  shop         String
  token        String
  name         String?
  addedAt      DateTime    @default(now())
  botSettings  Json?
  targetType   String?
  targetValue  Float?
  
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     Product[]
  syncHistory  SyncHistory[]
}

model SocialStore {
  id           String      @id @default(uuid())
  name         String
  type         String      @default("whatsapp")
  contact      String
  description  String?
  visits       Int         @default(0)
  inquiries    Int         @default(0)
  dailyStats   Json        @default("[]")
  productsJson Json        @default("[]") @map("products") // Keep old field for migration if needed
  createdAt    DateTime    @default(now())

  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     Product[]
}

model Product {
  id              String         @id @default(uuid())
  externalId      String?        @unique // Shopify GID
  title           String
  handle          String?
  description     String?
  vendor          String?
  productType     String?
  status          String         @default("active")
  price           Float          @default(0)
  compareAtPrice  Float?
  costPerItem     Float?
  inventory       Int            @default(0)
  images          Json           @default("[]")
  variants        Json           @default("[]")
  source          String         @default("manual") // "shopify", "instagram", "whatsapp", "manual"
  
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopifyStoreId  String?
  shopifyStore    ShopifyStore?  @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)
  
  socialStoreId   String?
  socialStore     SocialStore?   @relation(fields: [socialStoreId], references: [id], onDelete: Cascade)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Order {
  id              String      @id @default(uuid())
  storeId         String      // Compatibility field
  shopifyOrderId  String?     @unique // Shopify GID
  orderNumber     String?     // Shopify Display Number (e.g. #1001)
  items           Json
  totalAmount     Float
  currency        String
  customerName    String
  customerPhone   String?
  customerAddress String?
  customerEmail   String?
  financialStatus String      @default("pending")
  fulfillmentStatus String    @default("unfulfilled")
  source          String      @default("manual") // "shopify", "whatsapp", etc
  status          String      @default("pending")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyncHistory {
  id            String       @id @default(uuid())
  userId        String
  shopId        String?      // Optional ShopifyStore ID
  entityType    String       // "products", "orders", "all"
  status        String       // "success", "failed", "in_progress"
  results       Json?        // { "created": 10, "updated": 5, "errors": [] }
  startTime     DateTime     @default(now())
  endTime       DateTime?
  
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopifyStore  ShopifyStore? @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model TraceRecord {
  id          String   @id @default(uuid())
  userId      String
  action      String   // e.g. "VIEW_DASHBOARD", "EXPORT_REPORT"
  entityType  String?  // e.g. "order", "product"
  entityId    String?
  metadata    Json?
  timestamp   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String    @id @default(uuid())
  userId    String
  title     String    @default("New Chat")
  messages  Json      @default("[]")
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String    @id @default(uuid())
  email     String?
  rating    Int
  category  String    @default("general")
  message   String
  status    String    @default("new")
  createdAt DateTime  @default(now())
}



