generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  name                 String
  password             String?
  picture              String?
  shopifyShop          String?
  shopifyToken         String?
  activeShopId         String?
  storeLimit           Int            @default(2)
  retentionMonths      Int            @default(3)
  createdAt            String         // We mapped it as string (ISO text) earlier natively
  isOnboardingComplete Boolean        @default(false)
  refreshToken         String?
  aiTokens             Int            @default(500)
  reportTokens         Int            @default(250)
  botSettings          Json?
  lastTokenReset       Float?         // Stores epochs
  hasFreeReports       Boolean        @default(false)
  language             String         @default("en")
  pushSubscription     Json?
  ipAddress            String?
  location             String?
  currency             String?
  signInCount          Int            @default(0)
  lastLoginDate        String?        
  loginDates           String[]       @default([])

  // Relations
  shopifyStores        ShopifyStore[]
}

model ShopifyStore {
  id          String   @id @default(cuid())
  shop        String
  token       String
  name        String?
  addedAt     String   // Usually mapped as ISO string earlier
  botSettings Json?
  targetType  String?
  targetValue Float?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
